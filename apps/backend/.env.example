# Database (PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_interviewer"

# OpenAI API Key (for real-time voice interview via WebRTC)
OPENAI_KEY="sk-..."

# Google Gemini API Key (for interview result evaluation)
GEMINI_API_KEY="..."

# Proxy URL for GitHub scraping (optional, can be removed if not needed)
PROXY_URL="http://proxy-host:port"

# Deepgram API Key (for speech-to-text transcription)
DEEPGRAM_API_KEY=""

# Groq API Key and Model (for text/evaluation fallback)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
